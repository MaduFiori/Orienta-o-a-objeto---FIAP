<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="eurofarma" id="id-f2bf3269492d408b829cdac099e0d966" version="5.0.0">
  <folder name="Strategy" id="id-4d7776d0f8a1442e80a269d202827495" type="strategy"/>
  <folder name="Business" id="id-1fc2dfe1841b47db8a74ab6cad90101a" type="business"/>
  <folder name="Application" id="id-8d4b1d1fb8214f38aa4c44d08083b4fe" type="application"/>
  <folder name="Technology &amp; Physical" id="id-c96ec5639e69429cae03b8ba6e1794b3" type="technology"/>
  <folder name="Motivation" id="id-6672297c50364921b5e6f3e5952ed952" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Eurofarma" id="id-6ea993fceeab4af48aa436663b789883"/>
    <element xsi:type="archimate:Driver" name="Conectar nutrizes aos bancos de leite de forma simples, digital e eficiente, aumentando o número de doações" id="id-b579eff246774818a46cfe49f1b080de"/>
    <element xsi:type="archimate:Goal" name="Comunicação com o cliente demandante epara feedbacks" id="id-9d41d0a376aa4c9e8494768c6c880a58"/>
    <element xsi:type="archimate:Goal" name="Facilitar o acesso à informação sobre o projeto" id="id-e274d32cd9f14d94869edc1600761b46"/>
    <element xsi:type="archimate:Outcome" name="Entender a experiência da nutriz e melhorar continuamente o processo de doação" id="id-fdbb1a0be7fc4e0aa077ec3df3745df2"/>
    <element xsi:type="archimate:Goal" name="Entender a experiência da nutriz e melhorar continuamente o processo de doação" id="id-0e003815930a47f5abb79e2ecbfc5cdb"/>
    <element xsi:type="archimate:Outcome" name="Garantir 100% que todas as nutrizes sejam ouvidas através de um feedback após o processo de doação" id="id-4de19e01af074bd88ba704e9e042b6e2"/>
    <element xsi:type="archimate:Outcome" name="Outcome" id="id-37b758fcfb9847dbb2ff90c1ae4cfaaf"/>
    <element xsi:type="archimate:Outcome" name="Aumentar o nível de satisfação das nutrizes de forma gradual, a partir da implementação da solução" id="id-b985f4ab05b947678325eabb481c6b2f"/>
    <element xsi:type="archimate:Principle" name="Pesquisa de satisfação" id="id-9aaa84c997344854a94072408a1533e4"/>
    <element xsi:type="archimate:Principle" id="id-1114f46ae3b74bee8794b890aa2b1717"/>
    <element xsi:type="archimate:Outcome" name="Inserir QR codes em produtos infantis da Eurofarma para direcionar nutrizes a conteúdos e canais de doação" id="id-355c0237a5f84af9ad71c5c7ab56ac63"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-15fcdd17ddd04957816c6cf35ad2f1ae"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-041ebb7bb65c4719a1943d6430e9f8ad"/>
    <element xsi:type="archimate:Principle" name="Uso do forms para  cadastro das nutrizes" id="id-a8617c356db24612a229977ecb1da68e"/>
    <element xsi:type="archimate:Principle" name="Uso do whatsapp como principal forma de comunicação" id="id-3db6958753ab4c85a04f67e6a0ce23cd"/>
    <element xsi:type="archimate:Outcome" name="Melhorar a interface do site, trazendo mais informações sobre o Lactare, criar uma seção de acompanhamento da nutriz e mais acessibilidade referente a localização dos locais para doação" id="id-baa7db922b32415a881dfad571ed5874"/>
    <element xsi:type="archimate:Outcome" name="100% dos feedbacks das Nutrizes registrados no sistema de informação disponibilizado" id="id-73b26434957d41e4a7ecc89cd2e1ec12"/>
    <element xsi:type="archimate:Assessment" name="Usar solução de BI de mercado" id="id-5235d17c151d40e08a86a04d966bc21f"/>
    <element xsi:type="archimate:Requirement" name="Disparar pesquisa de satisfação" id="id-e80870bc6c9f40688c78e90c6d744007"/>
    <element xsi:type="archimate:Requirement" name="Coletar e guardar a resposta da pesquisa" id="id-05c256c5f4424f3a9ec02fb559f3df7c"/>
    <element xsi:type="archimate:Constraint" name="A mensagem deve conter um texto padrão explicando o objetivo da pesquisa, identificar o nome da nutriz e o cpf, acompanhado de uma lista de perguntas com opções de respostas pré configuradas" id="id-538502d942864d91a39ea2f6740f54c4"/>
    <element xsi:type="archimate:Constraint" name="Deve ser coletadas as respostas e guardar os seguintes dados: identificação da nutriz, cpf, identificação da pergunta e resposta da pergunta. Esses dados serão inseridos no banco de dados transacionais do Lactare para uso em consultas" id="id-8ebcc1e463a549798bf6b4edfdef0fba"/>
    <element xsi:type="archimate:Goal" name="Workflow da jornada completa da nutriz." id="id-61d8e28b67ba41dfbc0dcb7e78a49039"/>
    <element xsi:type="archimate:Requirement" name="A nutriz entra em contato com o Lactare através do whatsapp e escolhe umas das opções que serão mostradas pelo Bot " id="id-200bc85c02104d76b5b0d566d9de7a6f"/>
    <element xsi:type="archimate:Requirement" name="Após a escolha da opção, a nutriz será encaminhada para o atendimento humano" id="id-a2b907d5972544b4b7e74eec319c07ec"/>
    <element xsi:type="archimate:Requirement" id="id-7a800b8dc37e43c9a2fe9c8578582e22"/>
    <element xsi:type="archimate:Requirement" name="Registrar os dados da nutriz para seguir com a doação ou acompanhamento " id="id-63ec457b22f044089b706c58de75d5fe"/>
    <element xsi:type="archimate:Constraint" id="id-264407ec9aed445fa8e21171eaca8796"/>
    <element xsi:type="archimate:Constraint" name="Constraint" id="id-871018f192da4daebf38667d9df89c56"/>
  </folder>
